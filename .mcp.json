{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/Sites/nina/nina.fm-apps-workspace"
      ],
      "description": "Accès cross-repo à tout le workspace applicatif de Nina.fm"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "description": "Gestion GitHub : branches, PRs, issues, reviews"
    }
  }
}
